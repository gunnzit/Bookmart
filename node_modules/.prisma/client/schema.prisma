generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String        @id @default(cuid())
  name            String
  email           String        @unique
  phone           String?
  location        String?
  createdAt       DateTime      @default(now())
  clerkId         String?       @unique
  listings        Listing[]
  orders          Order[]
  wishlist        Wishlist[]
  bookRequests    BookRequest[]
  reviewsGiven    Review[]      @relation("ReviewsGiven")
  reviewsReceived Review[]      @relation("ReviewsReceived")
  kitOrders       KitOrder[]
}

model Listing {
  id        String     @id @default(cuid())
  title     String
  subtitle  String?
  price     Int
  origPrice Int?
  condition String
  category  String
  emoji     String?
  location  String
  sold      Boolean    @default(false)
  images    String[]   @default([])
  views     Int        @default(0)
  featured  Boolean    @default(false)
  createdAt DateTime   @default(now())
  sellerId  String
  seller    User       @relation(fields: [sellerId], references: [id])
  orders    Order[]
  wishlist  Wishlist[]
  status    String     @default("pending")
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
}

model Order {
  id        String   @id @default(cuid())
  status    String   @default("pending")
  amount    Int
  createdAt DateTime @default(now())
  buyerId   String
  listingId String
  buyer     User     @relation(fields: [buyerId], references: [id])
  listing   Listing  @relation(fields: [listingId], references: [id])
}

model KitOrder {
  id              String   @id @default(cuid())
  school          String
  class           String
  items           Json
  kitSubtotal     Int
  deliveryFee     Int      @default(0)
  totalAmount     Int
  paidNow         Int
  payLater        Int      @default(0)
  paymentMode     String
  deliveryMode    String
  address         String?
  buyerName       String
  buyerPhone      String
  buyerClerkId    String
  paymentId       String
  razorpayOrderId String
  status          String   @default("confirmed")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  userId          String
  user            User     @relation(fields: [userId], references: [id])
}

model Review {
  id         String   @id @default(cuid())
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())
  reviewerId String
  sellerId   String
  listingId  String?
  reviewer   User     @relation("ReviewsGiven", fields: [reviewerId], references: [id])
  seller     User     @relation("ReviewsReceived", fields: [sellerId], references: [id])
}

model BookRequest {
  id        String   @id @default(cuid())
  title     String
  author    String?
  category  String
  maxPrice  Int?
  location  String
  note      String?
  status    String   @default("open")
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OutOfStockItem {
  name      String   @id
  createdAt DateTime @default(now())
}

model StockNotify {
  id        String   @id @default(cuid())
  itemName  String
  phone     String
  buyerName String?
  notified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([itemName, phone])
  @@index([itemName])
}

model playing_with_neon {
  id    Int    @id @default(autoincrement())
  name  String
  value Float? @db.Real
}

model ProjectRequest {
  id               String   @id @default(cuid())
  userId           String
  buyerName        String   @default("")
  phone            String
  category         String
  topic            String
  classLevel       String
  deadline         DateTime
  size             String?
  description      String?
  photoUrl         String?
  status           String   @default("quote_requested")
  quotePrice       Int?
  advanceAmount    Int?
  quoteNote        String?
  advancePaidPaise Int      @default(0)
  balancePaidPaise Int      @default(0)
  advanceOrderId   String?
  advancePaymentId String?
  balanceOrderId   String?
  balancePaymentId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId])
  @@index([status])
}
